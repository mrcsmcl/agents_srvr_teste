COMPOSE_PROFILES=enabled

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=n8n
POSTGRES_NON_ROOT_USER=n8n_user
POSTGRES_NON_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Images and container names ---
POSTGRES_IMAGE=postgres:17
POSTGRES_CONTAINER_NAME=postgres
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=redis
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_CONTAINER_NAME=n8n
N8N_WORKER_CONTAINER_NAME=n8n_worker
WAHA_IMAGE=devlikeapro/waha:arm
WAHA_CONTAINER_NAME=waha
EVOLUTION_IMAGE=evoapicloud/evolution-api:latest
EVOLUTION_CONTAINER_NAME=evolution
NETWORK_NAME=HoloNet

# --- Runtime defaults ---
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
N8N_BASIC_AUTH_ACTIVE=true
N8N_SECURE_COOKIE=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis
QUEUE_HEALTH_CHECK_ACTIVE=true

# --- n8n ---
# Use a long random string for encryption key
N8N_ENCRYPTION_KEY=CHANGE_ME_RANDOM_STRING
# Container user (0:0 = root; use 1000:1000 if host dirs are already chowned to node)
N8N_USER=0:0
# Task runner (image version must match N8N_IMAGE version)
N8N_RUNNERS_IMAGE=n8nio/runners:latest
N8N_RUNNERS_MODE=external
# Shared secret between n8n/worker and the runner container
N8N_RUNNERS_AUTH_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_RUNNERS_TASK_BROKER_URI=http://n8n:5679
N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT=15
N8N_RUNNER_CONTAINER_NAME=n8n_runner
# IP or hostname of the server - change to your public IP/domain in production
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
NODE_ENV=production
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
GENERIC_TIMEZONE=UTC

# --- Redis ---
REDIS_USER=default
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- WAHA / WhatsApp ---
WHATSAPP_DEFAULT_ENGINE=GOWS
WHATSAPP_HOOK_EVENTS=message
WAHA_API_KEY=REPLACE_WITH_API_KEY
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
WHATSAPP_SWAGGER_USERNAME=swagger
WHATSAPP_SWAGGER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Evolution service ---
CONFIG_SESSION_PHONE_VERSION=1
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# URI do banco é construída automaticamente no docker-compose.yml a partir dos componentes acima
EVOLUTION_DB=evolution
DATABASE_CONNECTION_CLIENT_NAME=pg
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true
CACHE_REDIS_ENABLED=true
# CACHE_REDIS_URI é construída automaticamente no docker-compose.yml a partir de REDIS_PASSWORD
CACHE_REDIS_PREFIX_KEY=evolution:
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=true
AUTHENTICATION_API_KEY=REPLACE_WITH_API_KEY

# --- Bind mounts (host paths) - LINUX only ---
# Set HOST_BASE to a path where you want to store persistent data.
# Example: /var/lib/my-docker or /home/username/docker
HOST_BASE=/home/youruser/docker
HOST_DB_STORAGE=${HOST_BASE}/postgres/data
HOST_INIT_DB_SCRIPT=${HOST_BASE}/postgres/init-data.sh
HOST_N8N_STORAGE=${HOST_BASE}/n8n
HOST_REDIS_STORAGE=${HOST_BASE}/redis
HOST_WAHA_SESSIONS=${HOST_BASE}/waha/sessions
HOST_WAHA_MEDIA=${HOST_BASE}/waha/media
HOST_EVOLUTION_INSTANCES=${HOST_BASE}/evolution/instances

# --- Host ports ---
HOST_POSTGRES_PORT=54322
HOST_REDIS_PORT=6379
HOST_WAHA_PORT=3510
HOST_EVOLUTION_PORT=8480

# --- Healthcheck defaults ---
HC_INTERVAL=30s
HC_TIMEOUT=10s
HC_RETRIES=3
HC_START_PERIOD=60s

# Service-specific overrides
HC_INTERVAL_POSTGRES=30s
HC_TIMEOUT_POSTGRES=5s
HC_RETRIES_POSTGRES=5
HC_START_PERIOD_POSTGRES=20s

HC_INTERVAL_REDIS=30s
HC_TIMEOUT_REDIS=5s
HC_RETRIES_REDIS=5
HC_START_PERIOD_REDIS=10s

HC_INTERVAL_N8N=60s
HC_TIMEOUT_N8N=10s
HC_RETRIES_N8N=5
HC_START_PERIOD_N8N=180s

HC_INTERVAL_N8N_WORKER=60s
HC_TIMEOUT_N8N_WORKER=10s
HC_RETRIES_N8N_WORKER=3
HC_START_PERIOD_N8N_WORKER=60s

HC_INTERVAL_WAHA=60s
HC_TIMEOUT_WAHA=10s
HC_RETRIES_WAHA=3
HC_START_PERIOD_WAHA=90s

HC_INTERVAL_EVOLUTION=60s
HC_TIMEOUT_EVOLUTION=10s
HC_RETRIES_EVOLUTION=3
HC_START_PERIOD_EVOLUTION=60s
